{
  "app-id": "me.sanchezrodriguez.passes",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "passes",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland"
  ],
  "cleanup": [
    "/include",
    "/lib/cmake",
    "/share/man"
  ],
  "cleanup-commands": [
    "python3 -m compileall --invalidation-mode=unchecked-hash /app"
  ],
  "modules": [
    "zint.json",
    {
      "name": "passes",
      "builddir": true,
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/pablo-s/passes.git",
          "tag": "v0.10",
          "commit": "cbd32c0d2d5e8d5e4e385187bb08bd3581ebb3c9",
          "x-checker-data": {
            "type": "git",
            "tag-pattern": "^v([\\d.]+)$"
          }
        }
      ]
    }
  ]
}
